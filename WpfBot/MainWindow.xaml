<Window x:Class="WpfBot.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="CyberBot" Height="650" Width="950" WindowStartupLocation="CenterScreen" Background="#0B172A">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>
        <!-- Header -->
        <Border Grid.Row="0" Background="#133C73" CornerRadius="10" Padding="10">
            <DockPanel>
                <TextBlock Text="🛡" FontSize="32" Margin="10,0"/>
                <StackPanel>
                    <TextBlock Text="CyberBot" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Cybersecurity Awareness Assistant" FontSize="14" Foreground="White"/>
                </StackPanel>
            </DockPanel>
        </Border>
        <!-- Chat -->
        <Border Grid.Row="1" Margin="0,10,0,10" CornerRadius="10" Background="White">
            <ListBox x:Name="ChatBox" FontSize="15" BorderThickness="0" Background="White" Margin="10"/>
        </Border>
        <!-- Input -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="InputBox" FontSize="16" Margin="0,0,10,0" VerticalContentAlignment="Center" Padding="10"/>
            <Button x:Name="VoiceButton" Grid.Column="1" Content="🎤 Voice" Margin="5" FontWeight="Bold" Background="#1565C0" Foreground="White"/>
            <Button x:Name="SendButton" Grid.Column="2" Content="Send ➜" Margin="5" Click="Send_Click" FontWeight="Bold" Background="#2E7D32" Foreground="White"/>
        </Grid>
        <!-- Status -->
        <Border Grid.Row="3" Background="#133C73" CornerRadius="5">
            <TextBlock x:Name="StatusText" Text="Status : Ready" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
        </Border>
    </Grid>
</Window>