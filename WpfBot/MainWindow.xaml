<Window x:Class="WpfBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot" Height="680" Width="980"
        WindowStartupLocation="CenterScreen"
        Background="#0B172A">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#133C73" CornerRadius="10" Padding="10">
            <DockPanel>
                <TextBlock Text="CyberBot" FontSize="26" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
                <TextBlock Text="Cybersecurity Awareness Assistant" FontSize="14"
                           Foreground="#90CAF9" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="0,10,0,10"
                    Background="#0D1F3C"
                    BorderBrush="#1A3A6B">

            <TabItem Header="Chat">
                <Grid Background="#0D1F3C" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="55"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" CornerRadius="6" Background="#0B172A"
                            BorderBrush="#1A3A6B" BorderThickness="1" Margin="0,0,0,8">
                        <ListBox x:Name="ChatBox"
                                 FontSize="14"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#E3EAF4"
                                 Margin="8"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="InputBox"
                                 FontSize="14"
                                 Margin="0,0,8,0"
                                 VerticalContentAlignment="Center"
                                 Padding="8,0"
                                 Background="#132540"
                                 Foreground="White"
                                 CaretBrush="White"
                                 BorderBrush="#1A3A6B"
                                 KeyDown="InputBox_KeyDown"/>

                        <Button Grid.Column="1" Content="Send"
                                Background="#2E7D32" Foreground="White"
                                FontWeight="Bold" FontSize="13"
                                BorderThickness="0"
                                Click="Send_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Tasks">
                <Grid Background="#0D1F3C" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#0B172A" CornerRadius="6"
                            BorderBrush="#1A3A6B" BorderThickness="1"
                            Padding="10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                                       Text="Add New Task"
                                       Foreground="#90CAF9"
                                       FontWeight="Bold"
                                       FontSize="13"
                                       Margin="0,0,0,6"/>

                            <TextBox x:Name="TaskTitleBox"
                                     Grid.Row="1" Grid.Column="0"
                                     Margin="0,0,6,6"
                                     Padding="6,5" FontSize="13"
                                     Background="#132540" Foreground="White"
                                     CaretBrush="White" BorderBrush="#1A3A6B"/>

                            <TextBox x:Name="TaskDescBox"
                                     Grid.Row="1" Grid.Column="1"
                                     Margin="0,0,6,6"
                                     Padding="6,5" FontSize="13"
                                     Background="#132540" Foreground="White"
                                     CaretBrush="White" BorderBrush="#1A3A6B"/>

                            <Button Grid.Row="1" Grid.Column="2"
                                    Content="Add Task"
                                    Background="#1565C0" Foreground="White"
                                    FontWeight="Bold" FontSize="13"
                                    BorderThickness="0" Margin="0,0,0,6"
                                    Click="AddTask_Click"/>

                            <StackPanel Grid.Row="2" Grid.Column="0"
                                        Orientation="Horizontal">
                                <TextBlock Text="Remind in:"
                                           Foreground="#A0B4CC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           FontSize="13"/>
                                <ComboBox x:Name="ReminderCombo"
                                          Width="150" FontSize="13"
                                          SelectedIndex="0">
                                    <ComboBoxItem>No Reminder</ComboBoxItem>
                                    <ComboBoxItem>1 Day</ComboBoxItem>
                                    <ComboBoxItem>3 Days</ComboBoxItem>
                                    <ComboBoxItem>7 Days</ComboBoxItem>
                                    <ComboBoxItem>14 Days</ComboBoxItem>
                                    <ComboBoxItem>30 Days</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="#0B172A" CornerRadius="6"
                            BorderBrush="#1A3A6B" BorderThickness="1">
                        <ListView x:Name="TaskListView"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="White"
                                  FontSize="13">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Title" Width="190"
                                                    DisplayMemberBinding="{Binding Title}"/>
                                    <GridViewColumn Header="Description" Width="230"
                                                    DisplayMemberBinding="{Binding Description}"/>
                                    <GridViewColumn Header="Reminder" Width="150"
                                                    DisplayMemberBinding="{Binding ReminderDisplay}"/>
                                    <GridViewColumn Header="Status" Width="100"
                                                    DisplayMemberBinding="{Binding StatusDisplay}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="Mark Complete"
                                Background="#2E7D32" Foreground="White"
                                FontWeight="Bold" FontSize="13"
                                BorderThickness="0" Padding="12,6"
                                Margin="0,0,8,0"
                                Click="CompleteTask_Click"/>
                        <Button Content="Delete Task"
                                Background="#C62828" Foreground="White"
                                FontWeight="Bold" FontSize="13"
                                BorderThickness="0" Padding="12,6"
                                Click="DeleteTask_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Quiz">
                <Grid Background="#0D1F3C" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#0B172A" CornerRadius="6"
                            BorderBrush="#1A3A6B" BorderThickness="1"
                            Padding="10,8" Margin="0,0,0,8">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    x:Name="StartQuizBtn"
                                    Content="Start Quiz"
                                    Background="#1565C0" Foreground="White"
                                    FontWeight="Bold" FontSize="13"
                                    BorderThickness="0" Padding="12,6"
                                    Click="StartQuiz_Click"/>
                            <StackPanel>
                                <TextBlock x:Name="QuizStatusText"
                                           Text="Press Start Quiz to begin"
                                           Foreground="#90CAF9"
                                           FontWeight="Bold" FontSize="14"/>
                                <TextBlock x:Name="QuizScoreText"
                                           Text="Score: 0 / 0"
                                           Foreground="#A0B4CC" FontSize="12"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1" Background="#0B172A" CornerRadius="6"
                            BorderBrush="#1A3A6B" BorderThickness="1" Padding="14">
                        <StackPanel VerticalAlignment="Top">
                            <TextBlock x:Name="QuestionText"
                                       TextWrapping="Wrap"
                                       Foreground="White"
                                       FontSize="15" FontWeight="SemiBold"
                                       Margin="0,0,0,16"
                                       Text="Start the quiz to see questions here."/>

                            <ItemsControl x:Name="OptionsPanel">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding}"
                                                Background="#1565C0"
                                                Foreground="White"
                                                FontSize="13"
                                                BorderThickness="0"
                                                Padding="10,6"
                                                Margin="0,3"
                                                HorizontalAlignment="Left"
                                                MinWidth="300"
                                                Click="QuizOption_Click"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border x:Name="FeedbackBorder"
                                    CornerRadius="6" Padding="10"
                                    Margin="0,14,0,0"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="FeedbackText"
                                           TextWrapping="Wrap"
                                           FontSize="13"
                                           Foreground="White"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Button Grid.Row="2"
                            x:Name="NextQuestionBtn"
                            Content="Next Question"
                            Background="#1565C0" Foreground="White"
                            FontWeight="Bold" FontSize="13"
                            BorderThickness="0" Padding="12,6"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0"
                            Visibility="Collapsed"
                            Click="NextQuestion_Click"/>
                </Grid>
            </TabItem>

            <TabItem Header="Activity Log">
                <Grid Background="#0D1F3C" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#0B172A" CornerRadius="6"
                            BorderBrush="#1A3A6B" BorderThickness="1">
                        <ListBox x:Name="ActivityListBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#E3EAF4"
                                 FontSize="13"
                                 Margin="8"/>
                    </Border>

                    <Button Grid.Row="1"
                            Content="Refresh"
                            Background="#1565C0" Foreground="White"
                            FontWeight="Bold" FontSize="13"
                            BorderThickness="0" Padding="12,6"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0"
                            Click="RefreshLog_Click"/>
                </Grid>
            </TabItem>

        </TabControl>

        <Border Grid.Row="2" Background="#133C73" CornerRadius="5">
            <TextBlock x:Name="StatusText"
                       Text="Status: Ready"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="10,0"
                       FontSize="13"/>
        </Border>
    </Grid>
</Window>